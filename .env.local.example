# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Admin Password Hash (SHA-256 of your password)
NEXT_PUBLIC_ADMIN_PASSWORD_HASH=your_sha256_hash_here

# Dev Mode (skip login for development)
NEXT_PUBLIC_DEV_MODE=false

# Database direct connection (for scripts/init-db.mjs only — NOT exposed to frontend)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
